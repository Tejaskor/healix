# =========================================================================
# Frontend env (Vite reads anything prefixed with VITE_* into the client bundle)
# Copy this file to ".env.local" and fill in real values — `.env.local` is
# already in .gitignore (via the `*.local` pattern) so it stays out of git.
# Restart `npm run dev` after editing.
# =========================================================================

# Express auth backend (the one in /server). Leave as the dev proxy default
# unless you point the frontend at a different host.
VITE_API_BASE_URL=http://localhost:4000/api

# Supabase (Dashboard → Settings → API)
#   - VITE_SUPABASE_URL       : "Project URL"
#   - VITE_SUPABASE_ANON_KEY  : "anon / public" key (safe to ship)
# Do NOT put the "service_role" key here — that one bypasses RLS and is
# server-only.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

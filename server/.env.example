# Port the API listens on
PORT=4000

# Origin allowed to call the API (your frontend)
CLIENT_URL=http://localhost:3000

# Gmail credentials used by nodemailer.
# IMPORTANT: do NOT use your real Gmail password here.
# 1. Enable 2-Step Verification on your Google account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Paste that 16-char app password below
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-char-app-password

# "From" address shown on outgoing emails. Usually the same as EMAIL_USER.
EMAIL_FROM="Healix <your-email@gmail.com>"

# ---------------------------------------------------------------------------
# Sessions + OAuth
# ---------------------------------------------------------------------------
# Any long random string. In production use a secret manager.
SESSION_SECRET=change-me-to-a-long-random-string

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: {server-origin}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
